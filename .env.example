# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Unshorten API token (server-side secret, required by GET /api/unshorten)
UNSHORTEN_API_TOKEN=your-unshorten-token
# Public mirror the in-browser unshorten tab sends (set equal to UNSHORTEN_API_TOKEN)
NEXT_PUBLIC_UNSHORTEN_API_TOKEN=your-unshorten-token
